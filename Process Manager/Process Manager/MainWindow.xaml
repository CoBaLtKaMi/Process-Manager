<Window x:Class="ProcessManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessManager"
        xmlns:vm="clr-namespace:ProcessManager.ViewModels"
        xmlns:conv="clr-namespace:ProcessManager.Converters"
        mc:Ignorable="d"
        Title="Диспетчер процессов" Height="650" Width="1100">

    <Window.Resources>
        <conv:MemoryToMBConverter x:Key="MemoryToMB"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="220" Margin="0,0,10,0" VerticalAlignment="Center"/>

            <CheckBox Content="Только с GUI" IsChecked="{Binding ShowGuiOnly}" 
                      Margin="0,0,15,0" VerticalAlignment="Center"/>
            <CheckBox Content="Только системные" IsChecked="{Binding ShowSystemOnly}" 
                      Margin="0,0,20,0" VerticalAlignment="Center"/>

            <Button Content="Обновить" Command="{Binding RefreshCommand}" 
                    Margin="0,0,20,0" Padding="8,4"/>

            <!-- Убрана кнопка "Сорт. по имени" -->
            <Button Content="Сорт. по CPU" Command="{Binding SortByCpuCommand}" 
                    Margin="0,0,20,0" Padding="8,4"/>

            <TextBlock Text="Обновление каждые:" 
                       VerticalAlignment="Center" Margin="0,0,8,0"/>

            <ComboBox SelectedValue="{Binding UpdateIntervalSeconds}"
                      Width="110"
                      SelectedValuePath="Tag"
                      Margin="0,0,10,0">
                <ComboBoxItem Tag="1">1 сек</ComboBoxItem>
                <ComboBoxItem Tag="3">3 сек</ComboBoxItem>
                <ComboBoxItem Tag="5">5 сек</ComboBoxItem>
                <ComboBoxItem Tag="10">10 сек</ComboBoxItem>
                <ComboBoxItem Tag="30">30 сек</ComboBoxItem>
                <ComboBoxItem Tag="60">60 сек</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Список процессов">
                <DataGrid ItemsSource="{Binding Processes}" 
                          AutoGenerateColumns="False" 
                          SelectedItem="{Binding SelectedProcess}"
                          IsReadOnly="True"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID"     Binding="{Binding Id}"        Width="80"/>
                        <DataGridTextColumn Header="Имя"     Binding="{Binding Name}"      Width="*" CanUserSort="True"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="120"/>
                        <DataGridTextColumn Header="Память (МБ)" 
                                            Binding="{Binding MemoryUsage, Converter={StaticResource MemoryToMB}, StringFormat={}{0:N1}}" 
                                            Width="110"/>
                        <DataGridTextColumn Header="CPU время" Binding="{Binding CpuTime}"   Width="110"/>
                        <DataGridTextColumn Header="Потоки"   Binding="{Binding ThreadCount}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Дерево процессов">
                <TreeView ItemsSource="{Binding ProcessTree}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>

            <TabItem Header="Потоки">
                <DataGrid ItemsSource="{Binding Threads}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TID"         Binding="{Binding Id}"        Width="80"/>
                        <DataGridTextColumn Header="Приоритет"   Binding="{Binding Priority}" Width="120"/>
                        <DataGridTextColumn Header="Состояние"   Binding="{Binding State}"    Width="140"/>
                        <DataGridTextColumn Header="CPU время"   Binding="{Binding CpuTime}"  Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Нижняя панель -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
            <ComboBox ItemsSource="{Binding AvailablePriorities}" 
                      SelectedItem="{Binding SelectedPriority}" 
                      Width="160" Margin="0,0,10,0"/>

            <Button Content="Изменить приоритет" 
                    Command="{Binding ChangePriorityCommand}" 
                    Margin="0,0,20,0" Padding="10,6"/>

            <TextBlock Text="Ядра:" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <ItemsControl ItemsSource="{Binding SelectedCores}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding Path=., Mode=TwoWay}" 
                                  Margin="0,0,6,0"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding BinaryMask}" 
                       Margin="20,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding HexMask}"   
                       Margin="0,0,20,0" VerticalAlignment="Center"/>

            <Button Content="Применить Affinity" 
                    Command="{Binding ChangeAffinityCommand}" 
                    Margin="0,0,20,0" Padding="10,6"/>

            <Button Content="Завершить процесс" 
                    Command="{Binding KillCommand}" 
                    Background="#C62828" Foreground="White" Padding="10,6"/>
        </StackPanel>
    </Grid>
</Window>