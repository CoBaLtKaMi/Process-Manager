<Window x:Class="ProcessManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessManager"
        xmlns:vm="clr-namespace:ProcessManager.ViewModels"
        mc:Ignorable="d"
        Title="Диспетчер процессов" Height="600" Width="1000">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="5"/>
            <CheckBox Content="Только с GUI" IsChecked="{Binding ShowGuiOnly}" Margin="5"/>
            <CheckBox Content="Только системные" IsChecked="{Binding ShowSystemOnly}" Margin="5"/>
            <Button Content="Обновить" Command="{Binding RefreshCommand}" Margin="5"/>
            <Button Content="Сортировать по имени" Command="{Binding SortByNameCommand}" Margin="5"/>
            <Button Content="Сортировать по CPU" Command="{Binding SortByCpuCommand}" Margin="5"/>
        </StackPanel>
        <TabControl Grid.Row="1">
            <TabItem Header="Список процессов">
                <DataGrid ItemsSource="{Binding Processes}" AutoGenerateColumns="False" SelectedItem="{Binding SelectedProcess}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}"/>
                        <DataGridTextColumn Header="Память" Binding="{Binding MemoryUsage}"/>
                        <DataGridTextColumn Header="CPU время" Binding="{Binding CpuTime}"/>
                        <DataGridTextColumn Header="Потоки" Binding="{Binding ThreadCount}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Дерево процессов">
                <TreeView ItemsSource="{Binding ProcessTree}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>
            <TabItem Header="Потоки">
                <DataGrid ItemsSource="{Binding Threads}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TID" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}"/>
                        <DataGridTextColumn Header="Состояние" Binding="{Binding State}"/>
                        <DataGridTextColumn Header="CPU время" Binding="{Binding CpuTime}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <!-- Добавьте вкладки для визуализации, если нужно -->
        </TabControl>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8">
            <ComboBox ItemsSource="{Binding AvailablePriorities}"
              SelectedItem="{Binding SelectedPriority}"
              MinWidth="140" Margin="0,0,8,0"/>

            <Button Content="Применить приоритет"
            Command="{Binding ChangePriorityCommand}"
            Margin="0,0,16,0"/>

            <TextBlock Text="Ядра:" 
               VerticalAlignment="Center" 
               Margin="0,0,8,0"/>

            <ItemsControl ItemsSource="{Binding SelectedCores}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Вот исправление: явно указываем Path=. -->
                        <CheckBox IsChecked="{Binding Path=., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,0,6,0"
                          Content="{Binding RelativeSource={RelativeSource Self}, Path=Tag, FallbackValue='Ядро'}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding BinaryMask}" 
               Margin="16,0,8,0" 
               VerticalAlignment="Center"/>

            <TextBlock Text="{Binding HexMask}"   
               Margin="0,0,16,0" 
               VerticalAlignment="Center"/>

            <Button Content="Применить Affinity"
            Command="{Binding ChangeAffinityCommand}"
            Margin="0,0,16,0"/>

            <Button Content="Завершить процесс"
            Command="{Binding KillCommand}"
            Background="#C62828" 
            Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>